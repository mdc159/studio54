FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY pyproject.toml /app/pyproject.toml
COPY broker_service /app/broker_service

RUN pip install --no-cache-dir .

EXPOSE 8090

CMD ["uvicorn", "broker_service.app:app", "--host", "0.0.0.0", "--port", "8090"]
