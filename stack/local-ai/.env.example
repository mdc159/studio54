# Studio54 local-ai style bootstrap env
#
# First boot contract:
#   1. cp stack/local-ai/.env.example .env
#   2. set OPENROUTER_API_KEY
#   3. python3 stack/local-ai/start_studio54.py --profile none
#
# The launcher preserves existing values and generates local-only secrets.

# Node identity
NODE_NAME=nikolai
SITE_NAME=studio54

# Compose project
COMPOSE_PROJECT_NAME=studio54

# Shared Postgres with pgvector
POSTGRES_PASSWORD=replace-with-local-postgres-password
HONCHO_DATABASE_NAME=honcho
BROKER_DATABASE_NAME=postgres

# Honcho containerized memory service
HONCHO_BASE_URL=http://127.0.0.1:18000
HONCHO_NAMESPACE=studio54
HONCHO_WORKSPACE=studio54-main
HONCHO_OPERATOR_PEER=mike
HONCHO_AI_PEER=nikolai
HONCHO_LLM_MODEL=google/gemini-2.5-flash
HONCHO_LLM_BASE_URL=https://openrouter.ai/api/v1
HONCHO_EMBEDDING_PROVIDER=openrouter
HONCHO_AUTH_USE_AUTH=false
HONCHO_DERIVER_ENABLED=true

# Hermes host install/projection
HERMES_HOME=~/.hermes
HERMES_CONFIG_PATH=~/.hermes/config.yaml
HERMES_ENV_PATH=~/.hermes/.env
HERMES_HONCHO_CONFIG_PATH=~/.hermes/honcho.json
HERMES_MODEL_DEFAULT=google/gemini-2.5-flash
HERMES_MODEL_PROVIDER=openrouter
HERMES_MODEL_BASE_URL=https://openrouter.ai/api/v1

# Paperclip container
PAPERCLIP_USER_UID=1000
PAPERCLIP_USER_GID=1000
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_DEPLOYMENT_MODE=local_trusted
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
PAPERCLIP_AUTH_SECRET=replace-with-local-paperclip-auth-secret
PAPERCLIP_PUBLIC_URL=http://127.0.0.1:3100
PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_BROWSER_ORIGIN=http://127.0.0.1:3100
PAPERCLIP_AUTH_PUBLIC_BASE_URL=
PAPERCLIP_ALLOWED_HOSTNAMES=

# Optional Open WebUI convenience surface. Leave disabled with --profile none.
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPEN_WEBUI_DEFAULT_MODEL=google/gemini-2.5-flash

# Provider keys. OpenRouter is enough for first boot. OAuth can be added later.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
