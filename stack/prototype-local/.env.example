# 1215 prototype-local environment
#
# The prototype compose has built-in defaults so it can render without this
# file, but real values here make local testing less ambiguous.
#
# Active usage:
# - postgres: POSTGRES_PASSWORD
# - minio: MINIO_ROOT_PASSWORD
# - clickhouse/langfuse: CLICKHOUSE_PASSWORD
# - langfuse: LANGFUSE_SALT, ENCRYPTION_KEY, NEXTAUTH_SECRET
# - n8n: N8N_ENCRYPTION_KEY, N8N_USER_MANAGEMENT_JWT_SECRET
# - neo4j: NEO4J_AUTH
#
# This file is the committed contract. Generate a local `.env` from it with:
# python3 stack/prototype-local/scripts/init_env.py
#
# Re-rendering preserves existing local secrets so mounted service state does
# not drift from the generated `.env`.

# Postgres
POSTGRES_PASSWORD=replace-with-local-postgres-password

# MinIO
MINIO_ROOT_PASSWORD=replace-with-local-minio-password

# ClickHouse / Langfuse
CLICKHOUSE_PASSWORD=replace-with-local-clickhouse-password

# Langfuse
LANGFUSE_DATABASE_NAME=langfuse
LANGFUSE_SALT=replace-with-local-langfuse-salt
# Langfuse 3 requires 64 hex characters (openssl rand -hex 32)
ENCRYPTION_KEY=replace-with-64-char-hex-langfuse-key
NEXTAUTH_SECRET=replace-with-local-nextauth-secret

# n8n
N8N_BASE_IMAGE=n8nio/n8n:2.3.6
N8N_ENCRYPTION_KEY=replace-with-local-n8n-encryption-key
N8N_USER_MANAGEMENT_JWT_SECRET=replace-with-local-n8n-jwt-secret
N8N_API_KEY=
# Operator-owned first login:
# leave the initial owner identity blank by default, create the account in the
# n8n UI, then generate an API key from inside n8n and paste it here if
# n8n-mcp or other tooling needs it.
N8N_OWNER_EMAIL=
N8N_OWNER_FIRST_NAME=
N8N_OWNER_LAST_NAME=
N8N_OWNER_PASSWORD=
# File access remains restricted by default in n8n 2.x. The compose stack widens
# the allowlist to include /data/shared and disables n8n's internal block on
# ~/.n8n-files so Read Binary File can consume locally generated media before
# S3 upload.

# n8n-mcp
N8N_MCP_AUTH_TOKEN=replace-with-local-n8n-mcp-auth-token
N8N_MCP_LOG_LEVEL=info
N8N_MCP_REBUILD_ON_START=false
N8N_MCP_TELEMETRY_DISABLED=true

# Open WebUI
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui@sha256:eb874c0530209dd5ca21a4d0a7cc42e69f2ee85f0e7b90ae94659cd415c27c6d
# Operator-owned first login:
# leave the initial admin identity blank by default and create it through the
# Open WebUI signup flow on first access.
OPEN_WEBUI_ADMIN_EMAIL=
OPEN_WEBUI_ADMIN_NAME=
OPEN_WEBUI_ADMIN_PASSWORD=
# Generated in Open WebUI UI after first login: Settings -> Account -> API Keys.
# Leave blank on first init_env.py run; paste the generated key here afterward.
OPEN_WEBUI_API_KEY=

# ComfyUI
# These are used if the `media` profile is enabled.
COMFYUI_IMAGE=ghcr.io/lecode-official/comfyui-docker@sha256:e27739fc19d577d694ea99846a6c602e06dac963bebb2f056e22d97d19c392dd
COMFYUI_USER_ID=1000
COMFYUI_GROUP_ID=1000

# Neo4j
# Format: username/password
NEO4J_AUTH=neo4j/replace-with-local-neo4j-password

# Honcho (host-native under systemd --user; see stack/services/honcho/)
# The Honcho process runs on the host and reaches the shared substrate
# Postgres at 127.0.0.1:5433 as the postgres superuser. Its runtime env
# file (~/.config/1215-vps/honcho.env) is rendered from POSTGRES_PASSWORD
# and OPENROUTER_API_KEY by stack/services/honcho/install.sh, so the
# only Honcho-facing knobs kept here are topology (DB name, base URL).
HONCHO_DATABASE_NAME=honcho
HONCHO_BASE_URL=http://127.0.0.1:18000

# Broker app user password (next-stage DB/bootstrap wiring)
BROKER_APP_PASSWORD=replace-with-local-broker-app-password

# Langfuse project keys for downstream clients.
# The prototype defaults below are injected into Langfuse via the
# LANGFUSE_INIT_* env in docker-compose.substrate.yml, so a fresh
# langfuse-web boot auto-seeds the "1215 Continuity Plane" project
# with exactly these credentials. Rotate in the UI + re-render .env
# before any non-prototype deployment. See Phase G in
# docs/architecture/roadmap.md for the full instrumentation loop.
LANGFUSE_HOST=http://127.0.0.1:3000
LANGFUSE_PUBLIC_KEY=pk-lf-1215-prototype-public
LANGFUSE_SECRET_KEY=sk-lf-1215-prototype-secret
LANGFUSE_INIT_USER_EMAIL=prototype-owner@example.local
LANGFUSE_INIT_USER_NAME=Prototype Owner
LANGFUSE_INIT_USER_PASSWORD=replace-with-local-langfuse-password

# Paperclip (Phase E: in compose, not host-docker)
# The compose service binds 127.0.0.1:3100, lives in the compose network,
# reaches the broker at http://broker:8090. The current Donna reference-node
# contract does not require a live Hermes gateway socket.
PAPERCLIP_USER_UID=1000
PAPERCLIP_USER_GID=1000
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_DEPLOYMENT_MODE=local_trusted
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
PAPERCLIP_AUTH_SECRET=replace-with-local-paperclip-auth-secret
PAPERCLIP_PUBLIC_URL=http://127.0.0.1:3100
PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_BROWSER_ORIGIN=http://127.0.0.1:3100

# Upstream provider keys (leave blank until explicitly needed)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
