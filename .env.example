# 1215 reference-node operator contract
#
# This is the canonical operator env for the current Donna / Studio54
# reference-node shape.
#
# Current reality:
# - the live compose stack still reads stack/prototype-local/.env
# - Hermes still reads its own host-native config under /root/.hermes
#
# Intended operator workflow:
# 1. edit this root file first
# 2. project the relevant values into stack/prototype-local/.env
# 3. use docs/architecture/system-config-map.md for the few non-env surfaces
#
# Until the unified launcher exists, this file is the canonical control map,
# not yet the directly consumed runtime file for every subsystem.

# -----------------------------------------------------------------------------
# Node identity / topology
# -----------------------------------------------------------------------------
NODE_NAME=donna
SITE_NAME=studio54
DEPLOY_ROOT=/opt/1215-vps
STACK_ENV_PATH=/opt/1215-vps/stack/prototype-local/.env
TAILSCALE_HOSTNAME=donna.tailfedd3b.ts.net

# -----------------------------------------------------------------------------
# Hermes control plane pointers
# -----------------------------------------------------------------------------
HERMES_HOME=/root/.hermes
HERMES_CONFIG_PATH=/root/.hermes/config.yaml
HERMES_ENV_PATH=/root/.hermes/.env
HERMES_SOUL_PATH=/root/.hermes/SOUL.md
HERMES_HONCHO_CONFIG_PATH=/root/.hermes/honcho.json
HERMES_DASHBOARD_UNIT=/etc/systemd/system/hermes-dashboard.service
HERMES_DASHBOARD_HOST=donna.tailfedd3b.ts.net
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_URL=http://donna.tailfedd3b.ts.net:9119/
HERMES_MODEL_DEFAULT=google/gemini-2.5-flash
HERMES_MODEL_PROVIDER=openrouter
HERMES_MODEL_BASE_URL=https://openrouter.ai/api/v1

# -----------------------------------------------------------------------------
# Tailnet operator URLs
# -----------------------------------------------------------------------------
TAILNET_PAPERCLIP_URL=https://donna.tailfedd3b.ts.net:8443/
TAILNET_OPEN_WEBUI_URL=https://donna.tailfedd3b.ts.net:8444/
TAILNET_N8N_URL=https://donna.tailfedd3b.ts.net:8445/
TAILNET_LANGFUSE_URL=https://donna.tailfedd3b.ts.net:8446/
TAILNET_N8N_MCP_URL=https://donna.tailfedd3b.ts.net:8447/
TAILNET_NEO4J_URL=https://donna.tailfedd3b.ts.net:8448/
TAILNET_QDRANT_URL=https://donna.tailfedd3b.ts.net:8449/
TAILNET_MINIO_CONSOLE_URL=https://donna.tailfedd3b.ts.net:8450/
TAILNET_MINIO_S3_URL=https://donna.tailfedd3b.ts.net:8451/
TAILNET_COMFYUI_URL=https://donna.tailfedd3b.ts.net:8452/

# -----------------------------------------------------------------------------
# Local listener contract
# -----------------------------------------------------------------------------
BROKER_URL=http://127.0.0.1:8090
OPEN_WEBUI_URL=http://127.0.0.1:8080
N8N_URL=http://127.0.0.1:5678
N8N_MCP_URL=http://127.0.0.1:13000
LANGFUSE_URL=http://127.0.0.1:3000
PAPERCLIP_PUBLIC_URL=http://127.0.0.1:3100
PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_BROWSER_ORIGIN=http://127.0.0.1:3100
PAPERCLIP_AUTH_PUBLIC_BASE_URL=https://donna.tailfedd3b.ts.net:8443/
PAPERCLIP_ALLOWED_HOSTNAMES=donna.tailfedd3b.ts.net
PAPERCLIP_CONFIG_PATH=/paperclip/instances/default/config.json
PAPERCLIP_CONFIG_HOST_PATH=/var/lib/docker/volumes/1215-prototype-local_prototype_paperclip_data/_data/instances/default/config.json
PAPERCLIP_INSTANCE_ID=default
POSTGRES_URL=postgresql://postgres:${POSTGRES_PASSWORD}@127.0.0.1:5433/postgres
QDRANT_URL=http://127.0.0.1:6333
NEO4J_HTTP_URL=http://127.0.0.1:7474
MINIO_S3_URL=http://127.0.0.1:9010
MINIO_CONSOLE_URL=http://127.0.0.1:9011
COMFYUI_URL=http://127.0.0.1:8188
HONCHO_BASE_URL=http://127.0.0.1:18000

# -----------------------------------------------------------------------------
# Compose / app-plane secrets and runtime values
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=replace-with-local-postgres-password
MINIO_ROOT_PASSWORD=replace-with-local-minio-password
CLICKHOUSE_PASSWORD=replace-with-local-clickhouse-password

LANGFUSE_DATABASE_NAME=langfuse
LANGFUSE_SALT=replace-with-local-langfuse-salt
ENCRYPTION_KEY=replace-with-64-char-hex-langfuse-key
NEXTAUTH_SECRET=replace-with-local-nextauth-secret
LANGFUSE_HOST=http://127.0.0.1:3000
LANGFUSE_PUBLIC_KEY=pk-lf-1215-prototype-public
LANGFUSE_SECRET_KEY=sk-lf-1215-prototype-secret
LANGFUSE_INIT_USER_EMAIL=prototype-owner@example.local
LANGFUSE_INIT_USER_NAME=Prototype Owner
LANGFUSE_INIT_USER_PASSWORD=replace-with-local-langfuse-password

N8N_BASE_IMAGE=n8nio/n8n:2.3.6
